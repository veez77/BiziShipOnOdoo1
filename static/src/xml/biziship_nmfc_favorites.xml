<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <!-- Star button widget — renders just the amber star that opens the favorites dialog -->
    <t t-name="biziship.NmfcStarWidget">
        <button
            class="btn btn-sm btn-link p-0 ms-1 biziship-nmfc-fav-btn"
            t-on-click="openFavorites"
            title="NMFC Favorites">
            <i class="fa fa-star" style="color: #f59e0b; font-size: 1.1em;"/>
        </button>
    </t>

    <!-- NMFC Favorites Dialog -->
    <t t-name="biziship.NmfcFavoritesDialog">
        <Dialog title="'NMFC Favorites'" size="'md'">

            <!-- Filter input -->
            <div class="mb-3">
                <input
                    type="text"
                    class="form-control form-control-sm"
                    placeholder="Filter by description or NMFC…"
                    t-att-value="state.filter"
                    t-on-input="onFilterInput"
                    autofocus="true"
                />
            </div>

            <!-- Favorites list -->
            <div class="biziship-nmfc-fav-list mb-2" style="max-height: 300px; overflow-y: auto;">
                <t t-if="state.loading">
                    <div class="text-center text-muted py-4">
                        <i class="fa fa-spinner fa-spin me-2"/>Loading favorites…
                    </div>
                </t>
                <t t-elif="filteredFavorites.length === 0">
                    <div class="text-center text-muted py-4 fst-italic">
                        <t t-if="state.filter">No matches found.</t>
                        <t t-else="">No favorites saved yet.</t>
                    </div>
                </t>
                <t t-else="">
                    <t t-foreach="filteredFavorites" t-as="fav" t-key="fav.id">
                        <div class="d-flex align-items-center justify-content-between py-2 border-bottom">
                            <div class="flex-grow-1 me-3">
                                <div class="fw-semibold text-primary" style="font-size: 0.95em;">
                                    <t t-esc="fav.description"/>
                                </div>
                                <div class="text-muted" style="font-family: monospace; font-size: 0.82em;">
                                    <t t-esc="fav.nmfc_code"/>
                                </div>
                            </div>
                            <div class="d-flex align-items-center gap-2 flex-shrink-0">
                                <t t-if="state.confirmDeleteId === fav.id">
                                    <span class="text-danger fw-bold" style="font-size: 0.85em;">Delete?</span>
                                    <button
                                        class="btn btn-sm btn-danger py-0 px-2"
                                        t-on-click="() => this.onDeleteConfirm(fav.id)">
                                        Yes
                                    </button>
                                    <button
                                        class="btn btn-sm btn-outline-secondary py-0 px-2"
                                        t-on-click="onDeleteCancel">
                                        No
                                    </button>
                                </t>
                                <t t-else="">
                                    <button
                                        class="btn btn-sm btn-primary py-0 px-2"
                                        t-on-click="() => this.onUse(fav)">
                                        Use
                                    </button>
                                    <button
                                        class="btn btn-sm btn-link p-0 text-danger"
                                        t-on-click="() => this.onTrashClick(fav.id)"
                                        title="Delete favorite">
                                        <i class="fa fa-trash-o"/>
                                    </button>
                                </t>
                            </div>
                        </div>
                    </t>
                </t>
            </div>

            <!-- Add to Favorites section -->
            <hr class="my-3"/>
            <div class="biziship-nmfc-fav-add">
                <div class="text-uppercase fw-bold mb-2" style="font-size: 0.78em; letter-spacing: 0.05em; color: #6c757d;">
                    Add to Favorites
                </div>
                <div class="mb-2">
                    <input
                        type="text"
                        class="form-control form-control-sm"
                        placeholder="Description"
                        t-att-value="state.addDesc"
                        t-on-input="onAddDescInput"
                    />
                </div>
                <div class="mb-2">
                    <input
                        type="text"
                        class="form-control form-control-sm"
                        placeholder="NMFC Code (e.g. 181940)"
                        t-att-value="state.addNmfc"
                        t-on-input="onAddNmfcInput"
                    />
                </div>
                <t t-if="state.addError">
                    <div class="text-danger mb-2" style="font-size: 0.85em;">
                        <i class="fa fa-exclamation-circle me-1"/>
                        <t t-esc="state.addError"/>
                    </div>
                </t>
                <button
                    class="btn btn-sm btn-success"
                    t-on-click="onSave"
                    t-att-disabled="state.saving">
                    <i t-if="state.saving" class="fa fa-spinner fa-spin me-1"/>
                    <i t-else="" class="fa fa-plus me-1"/>
                    Save Favorite
                </button>
            </div>

        </Dialog>
    </t>

</templates>
