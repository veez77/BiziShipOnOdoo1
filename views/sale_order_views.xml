<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_biziship_inherit" model="ir.ui.view">
        <field name="name">sale.order.form.biziship.inherit</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="%(BiziShipOnOdoo1.action_biziship_bol_import_wizard)d"
                        string="BiziShip: Process BOL"
                        type="action"
                        class="oe_highlight"
                        invisible="state not in ['draft', 'sent', 'sale']"/>
            </xpath>
        </field>
    </record>
</odoo>
