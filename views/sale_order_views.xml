<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_biziship_inherit" model="ir.ui.view">
        <field name="name">sale.order.form.biziship.inherit</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="%(BiziShip.action_biziship_bol_import_wizard)d" string="BiziShip: Process BOL" type="action" class="btn-secondary" invisible="state not in ['draft', 'sent', 'sale']"/>
                <button name="action_demo_vinegar_order" string="Populate Demo Vinegar Order" type="object" class="btn-info" invisible="state != 'draft'"/>
            </xpath>
            <xpath expr="//field[@name='date_order']" position="attributes">
                <attribute name="widget">date</attribute>
                <attribute name="help"></attribute>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="LTL Freight Details" name="biziship_freight_details">
                    <field name="biziship_is_connected" invisible="1"/>
                    <field name="biziship_connected_user_name" invisible="1"/>
                    <field name="biziship_last_fetch_nonce" invisible="1"/>
                    <div class="alert alert-info py-1 mb-2 d-flex justify-content-between align-items-center" style="border-radius: 4px; border-left: 4px solid #00b14f;" invisible="not biziship_is_connected">
                        <div class="d-flex align-items-center">
                            <i class="fa fa-user-circle text-primary me-2" style="font-size: 1.1rem;"/>
                            <span>Logged in BiziShip as: <field name="biziship_connected_user_name" class="fw-bold ms-1"/></span>
                        </div>
                        <span class="badge rounded-pill bg-success-light text-success fw-bold px-3" style="font-size: 11px; border: 1px solid #00b14f;">ACCOUNT CONNECTED</span>
                    </div>
                    <div class="alert alert-warning py-1 mb-2" invisible="biziship_is_connected">
                        <i class="fa fa-exclamation-triangle me-1"/> 
                        <span>BiziShip account not connected. Please <button name="%(action_biziship_auth_wizard)d" string="Connect" type="action" class="btn btn-link p-0 align-baseline"/> to enable all features.</span>
                    </div>
                    <group string="Logistics Details">
                            <div class="d-flex align-items-center mb-2" colspan="2">
                                <button name="action_biziship_load_from_pool" string="Load Saved Freight" type="object" class="biziship-btn-pool-action me-2" icon="fa-folder-open-o"/>
                                <button name="action_biziship_save_to_pool" string="Save to My Pool" type="object" class="biziship-btn-pool-action" icon="fa-save"/>
                            </div>
                            <field name="biziship_po_number"/>
                            <field name="biziship_pickup_date"/>
                        </group>
                    <group>
                        <group name="biziship_origin_group">
                            <div colspan="2" class="d-flex align-items-center justify-content-between o_horizontal_separator mb-2 mt-0">
                                <span class="fw-bold">ORIGIN &amp; PICKUP</span>
                            </div>
                            <field name="biziship_origin_company" nolabel="1" colspan="2" placeholder="Origin Company Name"/>
                            <field name="biziship_origin_address" nolabel="1" colspan="2" placeholder="Address Line 1"/>
                            <field name="biziship_origin_address2" nolabel="1" colspan="2" placeholder="Address Line 2 (optional)"/>
                            <div class="d-flex w-100" colspan="2">
                                <field name="biziship_origin_city" placeholder="City" style="flex: 2; margin-right: 8px;"/>
                                <field name="biziship_origin_state_id" nolabel="1" placeholder="State" options="{'no_open': True, 'no_create': True}" style="flex: 1;" domain="[('country_id', '=?', biziship_origin_country_id)]"/>
                            </div>
                            <div class="d-flex w-100" colspan="2">
                                <field name="biziship_origin_zip" placeholder="Zip Code" style="flex: 2; margin-right: 8px;"/>
                                <field name="biziship_origin_country_id" nolabel="1" placeholder="Country" options="{'no_open': True, 'no_create': True}" domain="[('code', 'in', ('US', 'CA', 'MX'))]" style="flex: 1;"/>
                            </div>
                            <group colspan="2" class="mt-2">
                                <field name="biziship_origin_residential"/>
                                <field name="biziship_origin_liftgate"/>
                                <field name="biziship_origin_limited_access"/>
                            </group>
                            <div class="d-flex justify-content-between align-items-center mt-2 w-100" colspan="2">
                                <field name="biziship_origin_accessorial_ids" widget="many2many_tags" options="{'no_create': True}" placeholder="+ More Services" nolabel="1" style="flex-grow: 1;"/>
                                <button name="action_biziship_uncheck_all_origin" string="Uncheck all" type="object" class="btn btn-sm btn-link text-muted ms-2 p-0 text-nowrap" invisible="not biziship_origin_residential and not biziship_origin_liftgate and not biziship_origin_limited_access and not biziship_origin_accessorial_ids"/>
                            </div>
                        </group>
                        <group name="biziship_destination_group">
                            <div colspan="2" class="d-flex align-items-center justify-content-between o_horizontal_separator mb-2 mt-0">
                                <span class="fw-bold">DESTINATION</span>
                                <button name="action_biziship_copy_customer_to_dest" string="Copy Customer Details" type="object" class="btn btn-sm btn-link text-primary p-0" icon="fa-copy" invisible="not partner_id"/>
                            </div>
                            <field name="biziship_dest_company" nolabel="1" colspan="2" placeholder="Destination Company Name"/>
                            <field name="biziship_dest_address" nolabel="1" colspan="2" placeholder="Address Line 1"/>
                            <field name="biziship_dest_address2" nolabel="1" colspan="2" placeholder="Address Line 2 (optional)"/>
                            <div class="d-flex w-100" colspan="2">
                                <field name="biziship_dest_city" placeholder="City" style="flex: 2; margin-right: 8px;"/>
                                <field name="biziship_dest_state_id" nolabel="1" placeholder="State" options="{'no_open': True, 'no_create': True}" style="flex: 1;" domain="[('country_id', '=?', biziship_dest_country_id)]"/>
                            </div>
                            <div class="d-flex w-100" colspan="2">
                                <field name="biziship_dest_zip" placeholder="Zip Code" style="flex: 2; margin-right: 8px;"/>
                                <field name="biziship_dest_country_id" nolabel="1" placeholder="Country" options="{'no_open': True, 'no_create': True}" domain="[('code', 'in', ('US', 'CA', 'MX'))]" style="flex: 1;"/>
                            </div>
                            <group col="4" colspan="2" class="mt-2">
                                <field name="biziship_dest_appointment" colspan="2"/>
                                <field name="biziship_dest_residential" colspan="2"/>
                                <field name="biziship_dest_notify" colspan="2"/>
                                <field name="biziship_dest_limited_access" colspan="2"/>
                                <field name="biziship_dest_liftgate" colspan="2"/>
                                <field name="biziship_dest_hazmat" colspan="2"/>
                            </group>
                            <div class="d-flex justify-content-between align-items-center mt-2 w-100" colspan="2">
                                <field name="biziship_dest_accessorial_ids" widget="many2many_tags" options="{'no_create': True}" placeholder="+ More Services" nolabel="1" style="flex-grow: 1;"/>
                                <button name="action_biziship_uncheck_all_dest" string="Uncheck all" type="object" class="btn btn-sm btn-link text-muted ms-2 p-0 text-nowrap" invisible="not biziship_dest_appointment and not biziship_dest_residential and not biziship_dest_notify and not biziship_dest_limited_access and not biziship_dest_liftgate and not biziship_dest_hazmat and not biziship_dest_accessorial_ids"/>
                            </div>
                        </group>
                    </group>
                    <group string="Cargo Details">
                        <div colspan="2" class="d-flex align-items-center o_horizontal_separator mb-2 mt-0">
                            <span class="fw-bold">CARGO DETAILS</span>
                        </div>
                        
                        <field name="biziship_cargo_line_ids" nolabel="1" colspan="2" context="{'default_sale_order_id': id}">
                            <tree editable="bottom" class="biziship-cargo-tree">
                                <field name="packaging_type" />
                                <field name="pieces" decoration-danger="pieces == 0" />
                                <field name="weight" decoration-danger="weight == 0" />
                                <field name="weight_unit" />
                                <field name="last_weight_unit" column_invisible="True" />
                                <field name="length" decoration-danger="length == 0" />
                                <field name="width" decoration-danger="width == 0" />
                                <field name="height" decoration-danger="height == 0" />
                                <field name="dim_unit" />
                                <field name="last_dim_unit" column_invisible="True" />
                                <field name="computed_freight_class" string="Class" />
                                <field name="cargo_desc" />
                            </tree>
                        </field>
                        
                        <group name="cargo_footer" col="6" class="mt-2 mt-md-0">
                            <group colspan="4">
                            </group>
                            <group class="oe_subtotal_footer oe_right" colspan="2" name="cargo_total_weight">
                                <div class="oe_subtotal_footer_separator oe_inline o_td_label">
                                    <label for="biziship_total_weight" string="Total Weight"/>
                                </div>
                                <div class="oe_subtotal_footer_separator oe_inline">
                                    <field name="biziship_total_weight" nolabel="1" class="oe_inline oe_right" style="font-weight: bold; font-size: 1.2em;"/>
                                    <field name="biziship_total_weight_unit" nolabel="1" class="oe_inline ms-1"/>
                                </div>
                            </group>
                            <div class="oe_clear"/>
                        </group>
                        </group>
                    <div class="mt-4 text-center">
                        <style>
                            /* Modern Progress Bar for Fetch Quotes */
                            .biziship-fetch-progress-container {
                                display: none;
                                width: 100%;
                                max-width: 400px;
                                margin: 20px auto;
                            }
                            .biziship-fetch-progress-text {
                                text-align: center;
                                color: #495057;
                                font-weight: 500;
                                font-size: 14px;
                                margin-bottom: 8px;
                            }
                            .biziship-fetch-progress-wrapper {
                                width: 100%;
                                background-color: #e9ecef;
                                border-radius: 8px;
                                overflow: hidden;
                                height: 24px;
                                box-shadow: inset 0 1px 2px rgba(0,0,0,.1);
                            }
                            .biziship-fetch-progress-bar {
                                width: 0%;
                                height: 100%;
                                background-color: #714B67;
                                background-image: linear-gradient(45deg,rgba(255,255,255,.15) 25%,transparent 25%,transparent 50%,rgba(255,255,255,.15) 50%,rgba(255,255,255,.15) 75%,transparent 75%,transparent);
                                background-size: 1rem 1rem;
                            }
                            
                            /* We reuse the keyframes from the global/wizard css if present, or redefine them safely */
                            @keyframes biziship-fetch-stripes {
                                from { background-position: 1rem 0; }
                                to { background-position: 0 0; }
                            }
                            @keyframes biziship-fetch-fill {
                                0% { width: 0%; }
                                10% { width: 30%; }
                                50% { width: 60%; }
                                100% { width: 95%; }
                            }

                            /* Trigger: When Odoo disables the form or button during RPC call */
                            .o_form_view:has(button[name="action_biziship_fetch_live_quotes"]:disabled) .biziship-fetch-progress-container,
                            .o_form_view:has(button[name="action_biziship_fetch_live_quotes"].disabled) .biziship-fetch-progress-container,
                            .o_form_view:has(button[name="action_biziship_fetch_live_quotes"].o_disabled) .biziship-fetch-progress-container {
                                display: block;
                            }
                            .o_form_view:has(button[name="action_biziship_fetch_live_quotes"]:disabled) .biziship-fetch-progress-bar,
                            .o_form_view:has(button[name="action_biziship_fetch_live_quotes"].disabled) .biziship-fetch-progress-bar,
                            .o_form_view:has(button[name="action_biziship_fetch_live_quotes"].o_disabled) .biziship-fetch-progress-bar {
                                animation: biziship-fetch-fill 15s cubic-bezier(0.1, 0.7, 1.0, 0.1) forwards, biziship-fetch-stripes 1s linear infinite;
                            }

                            /* Highlight 0 weight/dimensions with light red background */
                            .biziship-cargo-tree .text-danger {
                                background-color: #f8d7da !important;
                                color: #721c24 !important;
                                font-weight: bold;
                                padding: 2px 4px;
                                border-radius: 3px;
                            }
                        </style>
                        <div class="biziship-fetch-progress-container">
                            <div class="biziship-fetch-progress-text">Fetching Live Quotes... (~15s)</div>
                            <div class="biziship-fetch-progress-wrapper">
                                <div class="biziship-fetch-progress-bar"></div>
                            </div>
                        </div>
                        <group name="special_instructions_group" class="mb-3">
                            <label for="biziship_special_instructions" style="font-size: 1.2rem; font-weight: bold;"/>
                            <field name="biziship_special_instructions" nolabel="1" placeholder="Enter special instructions for the carrier (e.g. fragile, call before delivery)..." style="font-size: 1.1em; text-align: left;"/>
                        </group>
                        

                        <button name="action_biziship_fetch_live_quotes" string="Get Live Quotes" type="object" class="biziship-btn-get-quotes" icon="fa-bolt" invisible="state not in ['draft', 'sent', 'sale']"/>
                    </div>
                </page>
                <page string="LTL Freight Quotes" name="biziship_freight_quotes">
                    <div class="alert alert-info py-1 mb-2 d-flex justify-content-between align-items-center" style="border-radius: 4px; border-left: 4px solid #00b14f;" invisible="not biziship_is_connected">
                        <div class="d-flex align-items-center">
                            <i class="fa fa-user-circle text-primary me-2" style="font-size: 1.1rem;"/>
                            <span>Logged in BiziShip as: <field name="biziship_connected_user_name" class="fw-bold ms-1"/></span>
                        </div>
                        <span class="badge rounded-pill bg-success-light text-success fw-bold px-3" style="font-size: 11px; border: 1px solid #00b14f;">ACCOUNT CONNECTED</span>
                    </div>
                    <group invisible="not biziship_shipment_id">
                        <group>
                            <div colspan="2" class="d-flex align-items-center o_horizontal_separator mb-2 mt-0">
                                <span class="text-uppercase fw-bold me-2">BiziShip Booking Details</span>
                                <button name="action_delete_biziship_booking" type="object" icon="fa-trash" class="btn btn-link text-muted p-0" title="Delete Booking Details" confirm="Are you sure you want to delete these booking details?"/>
                            </div>
                            <field name="biziship_bol_number" readonly="1"/>
                            <field name="biziship_shipment_id" readonly="1"/>
                            <field name="biziship_bol_url" invisible="1"/>
                            <field name="biziship_documents_html" nolabel="1" readonly="1" invisible="not biziship_bol_url and not biziship_documents_html"/>
                        </group>
                    </group>
                    <group invisible="not biziship_quote_ids">
                        <div colspan="2" class="d-flex align-items-center justify-content-between mb-2 mt-4" style="border-bottom: 1px solid #dee2e6; padding-bottom: 8px;">
                            <div class="d-flex align-items-center">
                                <span class="text-uppercase fw-bold me-2" style="font-size: 0.9rem; color: #495057;">Available Quotes</span>
                                <button name="action_delete_biziship_quotes" type="object" icon="fa-trash" class="btn btn-link text-muted p-0" title="Delete All Quotes" confirm="Are you sure you want to delete all quotes?"/>
                            </div>
                            <div class="d-flex align-items-center" invisible="biziship_priority1_env != 'PROD'">
                                <span class="badge rounded-pill bg-success text-white px-2 py-1" style="font-size: 11px; font-weight: bold; letter-spacing: 0.5px;">Live!</span>
                            </div>
                            <field name="biziship_priority1_env" invisible="1"/>
                        </div>
                    </group>
                    <field name="biziship_quote_ids" nolabel="1">
                        <tree string="Quotes" create="false" edit="false">
                            <field name="is_selected" column_invisible="True"/>
                            <button name="action_select_quote_toggle" type="object" icon="fa-lg fa-toggle-on text-success" invisible="not is_selected" class="btn btn-link p-0" title="Selected" aria-label="Selected"/>
                            <button name="action_select_quote_toggle" type="object" icon="fa-lg fa-toggle-off text-muted" invisible="is_selected" class="btn btn-link p-0" title="Select" aria-label="Not Selected"/>
                            <field name="carrier_logo" widget="image" options="{'size': [30, 30]}" class="me-2" nolabel="1" readonly="1" optional="show"/>
                            <field name="carrier_name" readonly="1"/>
                            <field name="service_level" readonly="1"/>
                            <field name="transit_days" readonly="1"/>
                            <field name="delivery_date" readonly="1"/>
                            <field name="total_charge" widget="monetary" options="{'currency_field': 'currency_id'}" readonly="1"/>
                            <field name="carrier_liability_new" widget="monetary" options="{'currency_field': 'currency_id'}" readonly="1" string="Carrier Liability New" invisible="carrier_liability_new == 0" optional="show"/>
                            <field name="carrier_liability_used" widget="monetary" options="{'currency_field': 'currency_id'}" readonly="1" string="Carrier Liability Used" invisible="carrier_liability_used == 0" optional="show"/>
                            <field name="currency" column_invisible="True" readonly="1"/>
                            <field name="currency_id" column_invisible="True"/>
                            <field name="quote_id_ref" readonly="1"/>
                        </tree>
                        <form string="Quote Details" create="false" edit="false">
                            <sheet>
                                <div class="d-flex align-items-center justify-content-between mb-3">
                                    <div class="oe_title mb-0">
                                        <h1 class="mb-0"><field name="carrier_name" readonly="1"/></h1>
                                    </div>
                                    <field name="carrier_logo" widget="image" class="ms-3" style="max-height: 50px; max-width: 150px; object-fit: contain;" readonly="1"/>
                                </div>
                                <group>
                                    <group>
                                        <field name="service_level" readonly="1"/>
                                        <field name="transit_days" readonly="1"/>
                                        <field name="delivery_date" readonly="1"/>
                                    </group>
                                    <group>
                                        <field name="total_charge" widget="monetary" options="{'currency_field': 'currency_id'}" readonly="1"/>
                                        <field name="carrier_liability_new" widget="monetary" options="{'currency_field': 'currency_id'}" readonly="1" invisible="carrier_liability_new == 0"/>
                                        <field name="carrier_liability_used" widget="monetary" options="{'currency_field': 'currency_id'}" readonly="1" invisible="carrier_liability_used == 0"/>
                                        <field name="currency" invisible="1" readonly="1"/>
                                        <field name="currency_id" invisible="1"/>
                                        <field name="quote_id_ref" readonly="1"/>
                                        <field name="is_selected" readonly="1"/>
                                    </group>
                                </group>
                                <group string="Terminal Information" invisible="not origin_terminal_city and not destination_terminal_city">
                                    <group>
                                        <label for="origin_terminal_city" string="Origin Terminal"/>
                                        <div class="o_row">
                                            <field name="origin_terminal_city" class="oe_inline" readonly="1" nolabel="1"/>
                                            <span invisible="not origin_terminal_state">, </span>
                                            <field name="origin_terminal_state" class="oe_inline" readonly="1" nolabel="1"/>
                                        </div>
                                        <field name="origin_terminal_phone" widget="phone" readonly="1" string="Phone"/>
                                    </group>
                                    <group>
                                        <label for="destination_terminal_city" string="Destination Terminal"/>
                                        <div class="o_row">
                                            <field name="destination_terminal_city" class="oe_inline" readonly="1" nolabel="1"/>
                                            <span invisible="not destination_terminal_state">, </span>
                                            <field name="destination_terminal_state" class="oe_inline" readonly="1" nolabel="1"/>
                                        </div>
                                        <field name="destination_terminal_phone" widget="phone" readonly="1" string="Phone"/>
                                    </group>
                                </group>
                                <notebook>
                                    <page string="Charge Breakdown" name="charge_breakdown">
                                        <field name="quote_details" readonly="1" widget="text" style="font-family: monospace; white-space: pre;"/>
                                    </page>
                                </notebook>
                                <footer>
                                    <button string="Close" class="btn-primary" special="cancel" data-hotkey="z"/>
                                </footer>
                            </sheet>
                        </form>
                    </field>
                    <div class="mt-4 text-center" invisible="not biziship_quote_ids">

                        <field name="biziship_has_selected_quote" invisible="1"/>
                        <button name="action_open_biziship_quote_confirm" type="object" string="Submit the chosen quote" class="btn-primary" invisible="not biziship_has_selected_quote"/>
                        <button name="action_open_biziship_quote_confirm" type="object" string="Submit the chosen quote" class="btn-secondary" invisible="biziship_has_selected_quote" title="Please select a quote first to submit it."/>
                    </div>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
