<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_biziship_load_freight_wizard_form" model="ir.ui.view">
        <field name="name">biziship.load.freight.wizard.form</field>
        <field name="model">biziship.load.freight.wizard</field>
        <field name="arch" type="xml">
            <form string="Load Saved Freight" class="biziship-modern-wizard">
                <div class="biziship-freight-pool-container">
                    <div class="mb-4 d-flex justify-content-between align-items-center">
                        <div>
                            <h2 class="mb-1" style="font-weight: 800; color: #0f172a;">My Freight Pool</h2>
                            <p class="text-muted mb-0">Saved freights for your company — launch one to get quotes instantly.</p>
                        </div>
                        <div class="text-muted">
                            <i class="fa fa-info-circle me-1"/> Select a template to pre-fill the form
                        </div>
                    </div>

                    <!-- Filter Bar - Matching Web App -->
                    <div class="biziship-filter-bar mb-3 d-flex gap-2">
                        <div class="biziship-search-container flex-grow-1">
                            <i class="fa fa-search biziship-search-icon"/>
                            <field name="search_name" placeholder="Search freight name..." nolabel="1" class="biziship-search-input biziship-autofilter"/>
                        </div>
                        <div class="biziship-filter-container d-flex align-items-center gap-2">
                            <span class="biziship-filter-label text-muted fw-bold small text-uppercase">By Person:</span>
                            <field name="filter_user_id" nolabel="1" class="biziship-filter-select" options="{'no_open': True, 'no_create': True}"/>
                        </div>
                    </div>
                    
                    <field name="sale_order_id" invisible="1"/>
                    <field name="raw_freights_json" invisible="1"/>
                    <div invisible="not status_message or status_message == ''" 
                         style="background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 12px; padding: 24px; margin-bottom: 20px; text-align: center;">
                        <i class="fa fa-info-circle fa-2x mb-3" style="color: #94a3b8;"/>
                        <field name="status_message" nolabel="1" style="display: block; color: #475569; font-size: 1.1rem; font-weight: 500;"/>
                    </div>
                    <field name="freight_line_ids" mode="kanban" nolabel="1">
                        <kanban create="false" edit="false" delete="false">
                            <field name="name"/>
                            <field name="origin_info"/>
                            <field name="summary_info"/>
                            <field name="creator_info"/>
                            <field name="freight_id"/>
                            <templates>
                                <t t-name="kanban-box">
                                    <div class="biziship-freight-card">
                                        <div class="biziship-card-icon">
                                            <i class="fa fa-file-text-o fa-2x"/>
                                        </div>
                                        <div class="biziship-card-content">
                                            <div class="biziship-card-title">
                                                <t t-esc="record.name.value"/>
                                            </div>
                                            <div class="biziship-card-summary">
                                                <i class="fa fa-truck me-2"/> 
                                                <t t-esc="record.origin_info.value"/>
                                            </div>
                                            <div class="biziship-card-summary" style="font-weight: 500;">
                                                <i class="fa fa-cube me-2"/>
                                                <t t-esc="record.summary_info.value"/>
                                            </div>
                                            <div class="biziship-card-creator mt-1">
                                                <i class="fa fa-user-circle-o me-2"/>
                                                <t t-esc="record.creator_info.value"/>
                                            </div>
                                        </div>
                                        <div>
                                            <button name="action_launch" type="object" class="btn biziship-launch-btn">
                                                <i class="fa fa-rocket"/> Launch
                                            </button>
                                        </div>
                                    </div>
                                </t>
                            </templates>
                        </kanban>
                    </field>
                </div>
                <footer>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
