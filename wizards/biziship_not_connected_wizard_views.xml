    <record id="action_biziship_not_connected_wizard" model="ir.actions.act_window">
        <field name="name">Connect BiziShip Account</field>
        <field name="res_model">biziship.not.connected.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
