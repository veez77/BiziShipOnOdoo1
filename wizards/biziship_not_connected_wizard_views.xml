            <form string="BiziShip Account Required">
                <style>
                    .modal-backdrop.show {
                        backdrop-filter: blur(4px);
                        background-color: rgba(0, 0, 0, 0.45);
                    }
                    .bz-nc-header {
                        background-color: #201f41;
                        padding: 22px 28px;
                        display: flex;
                        align-items: center;
                        justify-content: space-between;
                        border-radius: 12px 12px 0 0;
                    }
                    .bz-nc-body {
                        padding: 28px 32px 20px;
                        background: #fff;
                        text-align: center;
                    }
                    .bz-nc-body h4 {
                        color: #201f41;
                        font-weight: 700;
                        font-size: 18px;
                        margin-bottom: 12px;
                    }
                    .bz-nc-body p {
                        color: #555;
                        font-size: 14px;
                        line-height: 1.65;
                        max-width: 380px;
                        margin: 0 auto 8px;
                    }
                    .bz-nc-footer {
                        border-top: 1px solid #f0f0f0 !important;
                        padding: 18px 32px 24px !important;
                        display: flex !important;
                        justify-content: center !important;
                        gap: 12px !important;
                    }
                    .btn-bz-connect {
                        background-color: #f49800 !important;
                        border-color: #f49800 !important;
                        color: #fff !important;
                        font-weight: 700 !important;
                        font-size: 14px !important;
                        border-radius: 8px !important;
                        padding: 10px 28px !important;
                    }
                    .btn-bz-connect:hover {
                        background-color: #d98600 !important;
                        border-color: #d98600 !important;
                    }
                    .btn-bz-cancel {
                        background-color: #fff !important;
                        border: 1px solid #dee2e6 !important;
                        color: #666 !important;
                        font-size: 14px !important;
                        border-radius: 8px !important;
                        padding: 10px 24px !important;
                    }
