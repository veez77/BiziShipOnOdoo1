<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_biziship_quote_confirm_wizard_form" model="ir.ui.view">
        <field name="name">biziship.quote.confirm.wizard.form</field>
        <field name="model">biziship.quote.confirm.wizard</field>
        <field name="arch" type="xml">
            <form string="Confirm Quote Selection">
                <style>
                    /* Modern Progress Bar - Quote Booking */
                    .biziship-quote-progress-container {
                        display: none;
                        width: 100%;
                        margin-top: 20px;
                        margin-bottom: 20px;
                    }
                    .biziship-quote-progress-text {
                        text-align: center;
                        color: #495057;
                        font-weight: 500;
                        font-size: 14px;
                        margin-bottom: 8px;
                    }
                    .biziship-quote-progress-wrapper {
                        width: 100%;
                        background-color: #e9ecef;
                        border-radius: 8px;
                        overflow: hidden;
                        height: 24px;
                        box-shadow: inset 0 1px 2px rgba(0,0,0,.1);
                    }
                    .biziship-quote-progress-bar {
                        width: 0%;
                        height: 100%;
                        background-color: #714B67; /* Odoo Primary Purple */
                        background-image: linear-gradient(45deg,rgba(255,255,255,.15) 25%,transparent 25%,transparent 50%,rgba(255,255,255,.15) 50%,rgba(255,255,255,.15) 75%,transparent 75%,transparent);
                        background-size: 1rem 1rem;
                    }
                    @keyframes biziship-quote-stripes {
                        from { background-position: 1rem 0; }
                        to { background-position: 0 0; }
                    }
                    @keyframes biziship-quote-fill {
                        0% { width: 0%; }
                        100% { width: 95%; }
                    }

                    /* Trigger: When Odoo disables the primary button during RPC call, show animation! */
                    .modal:has(button[name="action_confirm_and_send"]:disabled) .biziship-quote-progress-container,
                    .modal:has(button[name="action_confirm_and_send"].o_disabled) .biziship-quote-progress-container {
                        display: block;
                    }
                    .modal:has(button[name="action_confirm_and_send"]:disabled) .biziship-quote-progress-bar,
                    .modal:has(button[name="action_confirm_and_send"].o_disabled) .biziship-quote-progress-bar {
                        /* 20 seconds for Quote Booking */
                        animation: biziship-quote-fill 20s cubic-bezier(0.1, 0.7, 1.0, 0.1) forwards, biziship-quote-stripes 1s linear infinite;
                    }
                    .modal:has(button[name="action_confirm_and_send"]:disabled) .biziship-quote-help-group,
                    .modal:has(button[name="action_confirm_and_send"].o_disabled) .biziship-quote-help-group {
                        display: none;
                    }
                </style>
                <div class="alert alert-info text-center biziship-quote-help-group" role="alert" style="font-size: 14px;">
                    Please confirm the details below to <b>submit the chosen quote</b>.
                </div>
                
                <div class="d-flex align-items-center justify-content-between biziship-quote-help-group mb-3">
                    <div class="oe_title mb-0">
                        <h1 class="mb-0"><field name="carrier_name" readonly="1"/></h1>
                    </div>
                    <field name="carrier_logo" widget="image" class="ms-3" style="max-height: 50px; max-width: 150px; object-fit: contain;" readonly="1"/>
                </div>

                <group class="biziship-quote-help-group">
                    <group>
                        <!-- Left column -->
                        <field name="delivery_date"/>
                        <field name="po_number"/>
                        <field name="has_accessorials" invisible="1"/>
                    </group>
                    <group>
                        <!-- Right column -->
                        <field name="total_charge" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                        <field name="carrier_liability_new" widget="monetary" options="{'currency_field': 'currency_id'}" invisible="carrier_liability_new == 0"/>
                        <field name="carrier_liability_used" widget="monetary" options="{'currency_field': 'currency_id'}" invisible="carrier_liability_used == 0"/>
                        <field name="currency" invisible="1"/>
                        <field name="currency_id" invisible="1"/>
                        <field name="quote_id_ref" string="Quote ID"/>
                        <field name="quote_id" invisible="1"/>
                        <field name="sale_order_id" invisible="1"/>
                    </group>
                </group>

                <group class="biziship-quote-help-group" string="Routing (Origin to Destination)">
                    <group string="Origin">
                        <field name="origin_company" nolabel="1" class="fw-bold mb-0" style="font-size: 1.1em; display: block;" colspan="2"/>
                        <div class="o_address_format" colspan="2">
                            <field name="origin_address" class="o_address_street"/>
                            <field name="origin_address2" class="o_address_street"/>
                            <field name="origin_city" class="o_address_city"/>
                            <field name="origin_state" class="o_address_state"/>
                            <field name="origin_zip" class="o_address_zip"/>
                        </div>
                        <field name="origin_phone" widget="phone" nolabel="1" colspan="2" style="display: block; white-space: nowrap;"/>
                        <field name="origin_contact_name" nolabel="1" colspan="2" readonly="1" invisible="not origin_contact_name" style="display: block;"/>
                        <field name="origin_contact_phone" nolabel="1" colspan="2" readonly="1" invisible="not origin_contact_phone" widget="phone" style="display: block; white-space: nowrap;"/>
                        <field name="origin_contact_email" nolabel="1" colspan="2" readonly="1" invisible="not origin_contact_email" style="display: block;"/>
                    </group>
                    <group string="Destination">
                        <field name="destination_company" nolabel="1" class="fw-bold mb-0" style="font-size: 1.1em; display: block;" colspan="2"/>
                        <div class="o_address_format" colspan="2">
                            <field name="destination_address" class="o_address_street"/>
                            <field name="destination_address2" class="o_address_street"/>
                            <field name="destination_city" class="o_address_city"/>
                            <field name="destination_state" class="o_address_state"/>
                            <field name="destination_zip" class="o_address_zip"/>
                        </div>
                        <field name="destination_phone" widget="phone" nolabel="1" colspan="2" style="display: block; white-space: nowrap;"/>
                        <field name="destination_contact_name" nolabel="1" colspan="2" readonly="1" invisible="not destination_contact_name" style="display: block;"/>
                        <field name="destination_contact_phone" nolabel="1" colspan="2" readonly="1" invisible="not destination_contact_phone" widget="phone" style="display: block; white-space: nowrap;"/>
                        <field name="destination_contact_email" nolabel="1" colspan="2" readonly="1" invisible="not destination_contact_email" style="display: block;"/>
                    </group>
                </group>

                <group class="biziship-quote-help-group" string="Carrier Terminals" invisible="not origin_terminal_city and not destination_terminal_city">
                    <group>
                        <label for="origin_terminal_city" string="Origin Terminal"/>
                        <div class="o_row">
                            <field name="origin_terminal_city" class="oe_inline" readonly="1" nolabel="1"/>
                            <span invisible="not origin_terminal_state">, </span>
                            <field name="origin_terminal_state" class="oe_inline" readonly="1" nolabel="1"/>
                        </div>
                        <field name="origin_terminal_phone" widget="phone" readonly="1" string="Phone"/>
                    </group>
                    <group>
                        <label for="destination_terminal_city" string="Destination Terminal"/>
                        <div class="o_row">
                            <field name="destination_terminal_city" class="oe_inline" readonly="1" nolabel="1"/>
                            <span invisible="not destination_terminal_state">, </span>
                            <field name="destination_terminal_state" class="oe_inline" readonly="1" nolabel="1"/>
                        </div>
                        <field name="destination_terminal_phone" widget="phone" readonly="1" string="Phone"/>
                    </group>
                </group>

                <notebook class="biziship-quote-help-group">
                    <page string="Freight Details" name="freight_details">
                        <div class="mb-2 mt-2">
                            <strong>Requested Pickup: </strong> <field name="biziship_pickup_date" readonly="1" class="oe_inline"/>
                        </div>
                        <field name="biziship_cargo_line_ids" nolabel="1" create="false" edit="false" delete="false">
                            <tree>
                                <field name="pieces" string="UNITS"/>
                                <field name="packaging_type" string="TYPE"/>
                                <field name="weight" string="WEIGHT"/>
                                <field name="weight_unit" nolabel="1" class="oe_inline"/>
                                <field name="length" string="L"/>
                                <field name="width" string="W"/>
                                <field name="height" string="H"/>
                                <field name="dim_unit" nolabel="1"/>
                                <field name="last_dim_unit" column_invisible="True"/>
                                <field name="cargo_desc" string="DESCRIPTION"/>
                                <field name="computed_freight_class" string="CLASS"/>
                                <field name="nmfc" string="NMFC" optional="show"/>
                            </tree>
                        </field>
                        <group name="cargo_footer" col="6" class="mt-2 mt-md-0">
                            <group colspan="4">
                                <field name="accessorial_services_text" string="Accessorials" readonly="1" invisible="not has_accessorials" style="white-space: pre; font-size: 13px; color: #666;"/>
                                <field name="biziship_special_instructions" string="Special Instructions" readonly="1" invisible="not biziship_special_instructions" style="white-space: pre; font-size: 1.1em; color: #000; text-align: left;"/>
                        
                        <!-- Environment Indicator -->
                        <div class="mt-4 mb-2 text-center" invisible="not priority1_env">
                            <span class="badge rounded-pill bg-warning text-dark px-3 py-2" style="font-size: 14px;" invisible="priority1_env != 'DEV'">
                                <i class="fa fa-flask me-1"></i> DEVELOPMENT ENVIRONMENT
                            </span>
                            <span class="badge rounded-pill bg-success text-white px-3 py-2" style="font-size: 14px;" invisible="priority1_env != 'PROD'">
                                <i class="fa fa-check-circle me-1"></i> PRODUCTION ENVIRONMENT (LIVE)
                            </span>
                            <field name="priority1_env" invisible="1"/>
                        </div>
                    </group>
                            <group class="oe_subtotal_footer oe_right" colspan="2" name="cargo_total_weight">
                                <div class="oe_subtotal_footer_separator oe_inline o_td_label">
                                    <label for="biziship_total_weight" string="Total Weight"/>
                                </div>
                                <div class="oe_subtotal_footer_separator oe_inline">
                                    <field name="biziship_total_weight" nolabel="1" class="oe_inline oe_right" style="font-weight: bold; font-size: 1.2em;"/>
                                    <field name="biziship_total_weight_unit" nolabel="1" class="oe_inline ms-1"/>
                                </div>
                            </group>
                            <div class="oe_clear"/>
                        </group>
                    </page>
                    <page string="Charge Breakdown" name="charge_breakdown">
                        <field name="quote_details" readonly="1" widget="text" style="font-family: monospace; white-space: pre; padding: 10px; background-color: #f9f9f9; border-radius: 4px;"/>
                    </page>
                </notebook>

                <div class="biziship-quote-progress-container">
                    <div class="biziship-quote-progress-text">Booking Quote... (~20s)</div>
                    <div class="biziship-quote-progress-wrapper">
                        <div class="biziship-quote-progress-bar"></div>
                    </div>
                </div>
                <footer>
                    <button name="action_confirm_and_send" string="Submit the chosen quote" type="object" class="btn-primary" data-hotkey="q"/>
                    <button string="Cancel" class="btn-secondary" special="cancel" data-hotkey="z"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_biziship_quote_confirm_wizard" model="ir.actions.act_window">
        <field name="name">Confirm Chosen Quote</field>
        <field name="res_model">biziship.quote.confirm.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
